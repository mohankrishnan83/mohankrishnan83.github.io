---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<BaseLayout title="Blog | Mohanakrishnan Rajamani">

<section class="max-w-4xl mx-auto px-6 py-16">

<h1 class="text-4xl font-bold mb-10">Technical Blog</h1>

<p class="text-gray-400 mb-12">
Insights on PostgreSQL architecture, database platforms,
cloud infrastructure, and enterprise data systems.
</p>

<div class="space-y-10">

{posts.map(post => (

  <article class="border-b border-gray-800 pb-8">

    <h2 class="text-2xl font-semibold">
      <a href={`/blog/${post.slug}`} class="hover:text-indigo-400">
        {post.data.title}
      </a>
    </h2>

    <p class="text-gray-400 mt-2">
      {post.data.description}
    </p>

    <p class="text-sm text-gray-500 mt-2">
      {post.data.pubDate}
    </p>

  </article>

))}

</div>

</section>

</BaseLayout>