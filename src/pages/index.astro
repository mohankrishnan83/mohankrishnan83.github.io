---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Mohanakrishnan Rajamani| PostgreSQL Specialist">

  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6">

    <h1 class="text-6xl font-extrabold mb-6">
      Mohanakrishnan Rajamani
    </h1>

    <p class="text-2xl text-indigo-400 mb-4">
      PostgreSQL Specialist & Database Architect
    </p>

    <p class="max-w-3xl text-gray-400 mb-8">
      Architecting high-performance PostgreSQL infrastructures,
      scalable data platforms, and cloud-native database systems
      that power mission-critical workloads.
    </p>

    <div class="flex gap-6">
      <a href="#projects" class="bg-indigo-600 px-6 py-3 rounded-lg hover:bg-indigo-500 transition">
        View Projects
      </a>
      <a href="#contact" class="border border-gray-600 px-6 py-3 rounded-lg hover:bg-gray-800 transition">
        Contact Me
      </a>
    </div>

  </section>

  <section id="expertise" class="py-20 px-6 bg-gray-900">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-4xl font-bold mb-12">Core Expertise</h2>

    <div class="grid md:grid-cols-3 gap-10 text-left">

      <div class="p-6 bg-gray-800 rounded-xl">
        <h3 class="text-xl font-semibold mb-4">Database Architecture</h3>
        <p class="text-gray-400">
          Logical & physical data modeling, performance tuning,
          high availability, replication, and migration strategies.
        </p>
      </div>

      <div class="p-6 bg-gray-800 rounded-xl">
        <h3 class="text-xl font-semibold mb-4">Cloud Infrastructure</h3>
        <p class="text-gray-400">
          Designing AWS & Azure-based database platforms
          with IaC, CI/CD pipelines, and automated scaling.
        </p>
      </div>

      <div class="p-6 bg-gray-800 rounded-xl">
        <h3 class="text-xl font-semibold mb-4">Data Platforms</h3>
        <p class="text-gray-400">
          Building modern data ecosystems integrating streaming,
          analytics, and governance frameworks.
        </p>
      </div>

    </div>
  </div>
</section>
<footer class="bg-gray-900 border-t border-gray-800 py-12 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-10 text-gray-400">

    <!-- Identity -->
    <div>
      <h3 class="text-white font-semibold mb-4">
        Mohanakrishnan Rajamani
      </h3>
      <p class="text-sm">
        Database & Cloud Architecture Consultant specializing in
        PostgreSQL performance, cloud-native infrastructure,
        and scalable data platforms.
      </p>
    </div>

    <!-- Navigation -->
    <div>
      <h4 class="text-white font-semibold mb-4">Explore</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="#expertise" class="hover:text-indigo-400">Expertise</a></li>
        <li><a href="#blog" class="hover:text-indigo-400">Blog</a></li>
        <li><a href="#projects" class="hover:text-indigo-400">Case Studies</a></li>
        <li><a href="#contact" class="hover:text-indigo-400">Work With Me</a></li>
      </ul>
    </div>

    <!-- Contact & Social -->
    <div>
      <h4 class="text-white font-semibold mb-4">Connect</h4>
      <p class="text-sm mb-3">
        <a href="mailto:mohan_krishnan83@yahoo.com" class="hover:text-indigo-400">
          mohan_krishnan83@yahoo.com
        </a>
      </p>
      <p class="text-sm">
        <a href="https://github.com/mohankrishnan83" target="_blank" class="hover:text-indigo-400">
          GitHub
        </a>
        ·
        <a href="https://www.linkedin.com/in/mohanakrishnan-rajamani/" target="_blank" class="hover:text-indigo-400">
          LinkedIn
        </a>
      </p>
    </div>

  </div>

  <div class="text-center text-xs text-gray-600 mt-10">
    © {new Date().getFullYear()} Mohanakrishnan Rajamani. All rights reserved.
  </div>
</footer>


</BaseLayout>


